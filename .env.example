# Application
APP_ENV=dev
DEBUG=false

# Local LLM server (OpenAI-compatible API, e.g. llama.cpp)
LOCAL_LLM_BASE_URL=http://host.docker.internal:8001/v1
LOCAL_LLM_API_KEY=dummy
LOCAL_LLM_MODEL=your-model-name
PROMPT_LANGUAGE=ru

# Embedding server
EMBEDDING_BASE_URL=http://host.docker.internal:8002
EMBEDDING_API_KEY=dummy
EMBEDDING_MODEL=nomic-embed-text-v1.5.Q4_K_M

# Bot
BOT_TOKEN=your-bot-token

# Internal services
BACKEND_BASE_URL=http://backend:8000
BACKEND_API_KEY=your-random-uuid-here

# Database
DATABASE_URL=postgresql+psycopg://groupbot:groupbot@db:5432/groupbot

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Pipeline tuning
BUFFER_DRAIN_INTERVAL_SECONDS=120

MERGE_TOPICS_INTERVAL_MINUTES=5
MERGE_TOPICS_LOOKBACK_HOURS=24
MERGE_SIMILARITY_THRESHOLD=0.90

SPLIT_TOPICS_INTERVAL_MINUTES=5
SPLIT_TOPICS_LOOKBACK_HOURS=24
SPLIT_TOPICS_MIN_MESSAGES=20

TOPIC_MIN_IMPORTANCE=6

# Vector similarity thresholds for topic matching
MATCH_CANDIDATE_THRESHOLD=0.82
MATCH_HIGH_CONFIDENCE_THRESHOLD=0.92
